# ── Jira Cloud credentials ────────────────────────────────────────────────
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_SITE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-api-token

# ── Per-client report config (CLI flags override these) ───────────────────
# Keep one file per client, e.g. .env.neuro, and run:
#   python generate_report.py --env-file .env.neuro
JIRA_PROJECT_KEY=NSO
# Jira project display name shown in the header. Leave blank to auto-fetch by key.
REPORT_PROJECT_NAME=
REPORT_CLIENT=Neuro
REPORT_TENANT=neuro.athenasecuritygrp.com
# Timezone (IANA name) for the "Generated" timestamp. Default: US Eastern (ET).
# e.g. America/Chicago (CT), Europe/London, Asia/Karachi.
REPORT_TIMEZONE=America/New_York
REPORT_SUPPORT_EMAIL=alerts@neuro.athenasecuritygrp.com
REPORT_WEEK_START=monday          # monday | sunday
REPORT_OUTPUT_DIR=reports         # where the HTML report is saved (inside this repo)
# Severities to show in the charts. Use * or ALL for every level.
REPORT_INCIDENT_SEVERITIES=CRITICAL,HIGH
# Vulnerability severities shown. Defaults to REPORT_INCIDENT_SEVERITIES if unset.
REPORT_VULN_SEVERITIES=CRITICAL,HIGH

# ── Response SLA targets (resolution time, in minutes) ─────────────────────
# Drives the "Response SLA attainment" card: % of incidents resolved within
# target, by severity. Defaults: Critical 240, High 480, Medium 1440, Low 4320.
REPORT_SLA_CRITICAL_MINUTES=240
REPORT_SLA_HIGH_MINUTES=480
REPORT_SLA_MEDIUM_MINUTES=1440
REPORT_SLA_LOW_MINUTES=4320

# Analyst narrative shown under the executive summary. By default it is
# AUTO-GENERATED from the week's metrics (volume, SLA attainment, top incident
# and classification, vuln remediation). Set REPORT_COMMENTARY_AUTO=false to omit
# it, or override with your own wording — a static line here, or (preferred)
# per-week via the "commentary" key in --supplemental JSON. Manual text wins.
REPORT_COMMENTARY_AUTO=true
# REPORT_COMMENTARY=A steadier week overall; all phishing quarantined at the gateway.

# ── Vulnerability remediation SLA targets (days) ───────────────────────────
# Drives the "Remediation SLA attainment" card in the Vulnerability section:
# % of vulnerabilities remediated within target, by severity. These differ from
# the incident-response SLA above (hours vs days). Defaults: 7 / 14 / 30 / 90.
REPORT_VULN_SLA_CRITICAL_DAYS=7
REPORT_VULN_SLA_HIGH_DAYS=14
REPORT_VULN_SLA_MEDIUM_DAYS=30
REPORT_VULN_SLA_LOW_DAYS=90

# ── Report section enablement ─────────────────────────────────────────────
REPORT_ENABLE_DEVICE_MANAGEMENT=true
REPORT_ENABLE_ENDPOINT_MANAGEMENT=true
REPORT_ENABLE_VULNERABILITY_STATUS=true
REPORT_ENABLE_SYSTEM_AVAILABILITY=true

# ── Severity mapping (defaults match Athena/SECOPS + Palace) ───────────────
# Incidents/alerts: mirror Palace's own values. Sev-1 = confirmed compromise.
# Default: Critical=Sev-2, High=Sev-3, Medium & Low=Sev-4.
JIRA_SEVERITY_CONFIRMED_VALUE=Sev-1
JIRA_SEVERITY_CRITICAL_VALUE=Sev-2
JIRA_SEVERITY_HIGH_VALUE=Sev-3
JIRA_SEVERITY_MEDIUM_VALUE=Sev-4
JIRA_SEVERITY_LOW_VALUE=Sev-4
# Vulnerabilities (Snyk import, natural): Critical=Sev-1 … Low=Sev-4.
JIRA_VULN_SEVERITY_CRITICAL_VALUE=Sev-1
JIRA_VULN_SEVERITY_HIGH_VALUE=Sev-2
JIRA_VULN_SEVERITY_MEDIUM_VALUE=Sev-3
JIRA_VULN_SEVERITY_LOW_VALUE=Sev-4

# ── Email delivery via Entra app + Microsoft Graph ─────────────────────────
# Requires Microsoft Graph Mail.Send application permission with admin consent.
# Nothing is ever sent unless you pass --send-email.
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=
REPORT_EMAIL_FROM=alerts@athenasecuritygrp.com
REPORT_EMAIL_TO=client-contact@neuro.example.com
REPORT_EMAIL_CC=soc-team@athenasecuritygrp.com
REPORT_EMAIL_BCC=
REPORT_EMAIL_SUBJECT="Weekly Security Operations Report — {client} — {period}"
REPORT_EMAIL_SAVE_TO_SENT_ITEMS=true
# The full SVG report (charts/colours) does NOT render inside email clients
# (Outlook/Gmail strip SVG + modern CSS). So by default the email body is the
# table-based "email-safe" rendering, and the pretty report is attached as an
# .html file that opens perfectly in a browser.
REPORT_EMAIL_ATTACH_REPORT=true
# Inline body: "email" = table-based, renders everywhere (recommended);
# "full" = the SVG report inline — looks great in Apple Mail / browser previews
# but breaks in Outlook & Gmail.
REPORT_EMAIL_BODY=email
