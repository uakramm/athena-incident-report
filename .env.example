# ── Jira Cloud credentials ────────────────────────────────────────────────
# Create an API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_SITE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-api-token

# ── Per-client report config (CLI flags override these) ───────────────────
# Keep one file per client, e.g. .env.neuro, and run:
#   python generate_report.py --env-file .env.neuro
JIRA_PROJECT_KEY=NSO
REPORT_CLIENT=Neuro
REPORT_ENVIRONMENT=Production
REPORT_TENANT=neuro.athenasecuritygrp.com
REPORT_SUPPORT_EMAIL=alerts@neuro.athenasecuritygrp.com
REPORT_WEEK_START=monday          # monday | sunday
REPORT_OUTPUT_DIR=reports         # where the HTML report is saved (inside this repo)
# Severities to show in the charts. Use * or ALL for every level.
REPORT_INCIDENT_SEVERITIES=CRITICAL,HIGH
# Vulnerability severities shown. Defaults to REPORT_INCIDENT_SEVERITIES if unset.
REPORT_VULN_SEVERITIES=CRITICAL,HIGH

# ── Report section enablement ─────────────────────────────────────────────
REPORT_ENABLE_DEVICE_MANAGEMENT=true
REPORT_ENABLE_ENDPOINT_MANAGEMENT=true
REPORT_ENABLE_VULNERABILITY_STATUS=true
REPORT_ENABLE_SYSTEM_AVAILABILITY=true

# ── Severity mapping (defaults match Athena/SECOPS + Palace) ───────────────
# Incidents/alerts: mirror Palace's own values. Sev-1 = confirmed compromise.
# Default: Critical=Sev-2, High=Sev-3, Medium & Low=Sev-4.
JIRA_SEVERITY_CONFIRMED_VALUE=Sev-1
JIRA_SEVERITY_CRITICAL_VALUE=Sev-2
JIRA_SEVERITY_HIGH_VALUE=Sev-3
JIRA_SEVERITY_MEDIUM_VALUE=Sev-4
JIRA_SEVERITY_LOW_VALUE=Sev-4
# Vulnerabilities (Snyk import, natural): Critical=Sev-1 … Low=Sev-4.
JIRA_VULN_SEVERITY_CRITICAL_VALUE=Sev-1
JIRA_VULN_SEVERITY_HIGH_VALUE=Sev-2
JIRA_VULN_SEVERITY_MEDIUM_VALUE=Sev-3
JIRA_VULN_SEVERITY_LOW_VALUE=Sev-4
