# ----- Email delivery configuration -----
REPORT_EMAIL_TO=client-contact@example.com
REPORT_EMAIL_CC=soc-team@athenasecuritygrp.com

# ----- Jira Cloud credentials -----
JIRA_SITE_URL=https://your-domain.atlassian.net

# Option 1) OAuth 2.0 client credentials. When both are set they take precedence.
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
#
# Option 2) API token
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-api-token

JIRA_PROJECT_KEY=
REPORT_CLIENT=<TENANT_NAME>
REPORT_TENANT=<TENANT_NAME>.athenasecuritygrp.com

# Timezone (IANA name) for the "Generated" timestamp. Default: US Eastern (ET).
REPORT_TIMEZONE=America/New_York

# ----- Incident response SLA targets (resolution time, in minutes) -----
# Drives the "Response SLA attainment" card: % of incidents resolved within
# target, by severity.
REPORT_SLA_CRITICAL_MINUTES=240
REPORT_SLA_HIGH_MINUTES=480
REPORT_SLA_MEDIUM_MINUTES=1440
REPORT_SLA_LOW_MINUTES=4320

# ----- Vulnerability remediation SLA targets (days) -----
# Drives the "Remediation SLA attainment" card in the Vulnerability section:
# % of vulnerabilities remediated within target, by severity. These differ from
# the incident-response SLA above (hours vs days).
REPORT_VULN_SLA_CRITICAL_DAYS=7
REPORT_VULN_SLA_HIGH_DAYS=14
REPORT_VULN_SLA_MEDIUM_DAYS=30
REPORT_VULN_SLA_LOW_DAYS=90

# ----- Standard incident severity mapping -----
JIRA_SEVERITY_CRITICAL_VALUE=Sev-1
JIRA_SEVERITY_HIGH_VALUE=Sev-2
JIRA_SEVERITY_MEDIUM_VALUE=Sev-3
JIRA_SEVERITY_LOW_VALUE=Sev-4

# ----- NIDS severity mapping (tickets with [SURICATA] in the summary) -----
JIRA_NIDS_SEVERITY_CONFIRMED_VALUE=Sev-1
JIRA_NIDS_SEVERITY_CRITICAL_VALUE=Sev-2
JIRA_NIDS_SEVERITY_HIGH_VALUE=Sev-3
JIRA_NIDS_SEVERITY_MEDIUM_VALUE=Sev-4
JIRA_NIDS_SEVERITY_LOW_VALUE=Sev-4

# ----- Vulnerabilities Severity mapping -----
JIRA_VULN_SEVERITY_CRITICAL_VALUE=Sev-1
JIRA_VULN_SEVERITY_HIGH_VALUE=Sev-2
JIRA_VULN_SEVERITY_MEDIUM_VALUE=Sev-3
JIRA_VULN_SEVERITY_LOW_VALUE=Sev-4

# ----- Email delivery Configuration-----
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=
REPORT_EMAIL_SUBJECT="Weekly Security Operations Report - {client} - {period}"
